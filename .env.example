# ============================================
# MAC - My Agent Capture  環境変数テンプレート
# このファイルを .env にコピーして値を設定してください
# ============================================

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Google Service Account (JSONキーファイルのパス)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# Google Spreadsheet (案件表のスプレッドシートID)
GOOGLE_SPREADSHEET_ID=

# Google Drive (物件管理ルートフォルダのID)
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ファイル共有設定 (true=誰でもリンクで閲覧可能, false=非公開)
DRIVE_PUBLIC_SHARE=false

# Gemini AI (OCR用APIキー)
GEMINI_API_KEY=

# Google Maps API (任意)
GOOGLE_MAPS_API_KEY=

# 国土交通省 不動産情報ライブラリ API
MLIT_API_KEY=cc077c568d8e4b0e917cb0660298821e

# アプリ設定
AGENT_NAME=担当者名
COMPANY_NAME=会社名
WEBHOOK_URL=
SOURCE_OPTIONS=紹介,仲介,買取

# サーバー設定
PORT=3000
LOG_LEVEL=info
